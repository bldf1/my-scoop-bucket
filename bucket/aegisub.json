{
    "version": "3.5.1",
    "description": "该版本基于 arch1t3cht 分支开发，增加了针对中文用户的优化（如字体渲染、快捷键等）。",
    "homepage": "https://github.com/mojie126/Aegisub",
    "license": {
        "identifier": "BSD-3-Clause,MIT,BSDL,MPL-1.1",
        "url": "https://github.com/mojie126/Aegisub/blob/master/LICENCE"
    },
    "suggest": {
        "vcredist": "extras/vcredist2022"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/mojie126/Aegisub/releases/download/3.5.1/Aegisub-3.5.1-win64-portable.zip",
            "hash": "5c6878eef3f207d1b368e3affea20376bb9d43eb98af004bc4fa3af0c3c652f9"
        }
    },
    "extract_dir": "aegisub-portable",
    "shortcuts": [
        [
            "Aegisub.exe",
            "Aegisub"
        ]
    ],
    "persist": [
        "autoback",
        "automation",
        "autosave",
        "catalog",
        "config"
    ],
    "pre_install": [
        "# config.json is recreated on launch instead of being overwritten, so hardlinks break persistence.",
        "'config.json' | ForEach-Object {",
        "    if (Test-Path -LiteralPath \"$persist_dir\\$_\" -PathType Leaf) {",
        "        Copy-Item -Path \"$persist_dir\\$_\" -Destination \"$dir\\$_\" -Force",
        "    }",
        "}"
    ],
    "post_install": [
        "'automation' | ForEach-Object {",
        "    if (Test-Path -Path \"$dir\\$_.original\" -PathType Container) {",
        "        Copy-Item -Path \"$dir\\$_.original\\*\" -Destination \"$dir\\$_\" -Force -Recurse",
        "        Remove-Item -Path \"$dir\\$_.original\" -Recurse -Force -ErrorAction SilentlyContinue",
        "    }",
        "}"
    ],
    "pre_uninstall": [
        "# Persist config files that are recreated rather than overwritten.",
        "'config.json' | ForEach-Object {",
        "    if (Test-Path -LiteralPath \"$dir\\$_\" -PathType Leaf) {",
        "        ensure $persist_dir | Out-Null",
        "        Copy-Item -Path \"$dir\\$_\" -Destination \"$persist_dir\\$_\" -Force",
        "    }",
        "}"
    ],
    "checkver": {
        "github": "https://github.com/mojie126/Aegisub",
        "regex": "Aegisub-([\\d.]+)-win64-portable\\.zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/mojie126/Aegisub/releases/download/$matchTag/Aegisub-$version-win64-portable.zip"
            }
        }
    }
}